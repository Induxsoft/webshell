#include "dkli.dkh"
#!
module "controller"
{
    switch @@(@http_context,"$request/get/_view")
    {
        case "check_redir"
        {
            point @read to notif.check_redir
            break
        }
        case "check_readed"
        {
            point @update to notif.check_all
            break
        }
    }
}