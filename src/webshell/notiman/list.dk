#include "dkli.dkh"
#!
module "Administración de notificaciones"
{
    #include "functions.dkh"
    #include "serialize.dkh"
    #include "uielements.v12.dkl"
    #include "webshell/config.dk"

    do @context.begin(@crud_context)

    ref @_GET = ifnull(@("&parameters"),record.create())
    ref data = ifnull(@("&./data"),list.create())

    @_entities_type = @("$parameters/_entities_type")

    table_id = "tbl_"+@_entities_type
    show_tab = @("$parameters/_show")
    show_fdr = isanyword(show_tab,"leidas,enviadas")

    curr_ndt = ndatetime.now()
    curr_year = ndatetime.year(curr_ndt)
    curr_month = ndatetime.month(curr_ndt)
    curr_day = ndatetime.day(curr_ndt)

    fdr_year_opt = ""
    for i = 2024; i <= curr_year { fdr_year_opt = fdr_year_opt + str(i) + "," }
    fdr_year_opt = rremove(fdr_year_opt,1)

    new fdr_init
    {
        @"fdr_mode": field.dstr(@_GET,"fdr_mode","lastdays")
        // [month]
        @"fdr_year": field.dnum(@_GET,"fdr_year",curr_year)
        @"fdr_month": field.dnum(@_GET,"fdr_month",curr_month)
        // [lastdays]
        @"fdr_range": field.dnum(@_GET,"fdr_range",15)
        // [range]
        @"fdr_from": field.dstr(@_GET,"fdr_from","")
        @"fdr_to": field.dstr(@_GET,"fdr_to","")
    }

    new fil_fdr_field
    {
        @"datatable*": from.json('[
            {"id":1, "const":"Inicio"},
            {"id":2, "const":"Cierre"}
        ]')
        member "attributes"
        {
            @"name": "fdr_field"
            @"class": "induxsoft-form-select"
            @"title": "Elegir método de filtro para el rango de fechas"
            @"onchange": "filter(this);"
        }
        @"value_field": "id"
        @"text_field": "const"
        @"selected": @("#parameters/fdr_field")
    }

    new fil_limit
    {
        @"datatable*": from.json('[
            {"v":-1, "t":"(Todos)"},
            {"v":10, "t":"10"},
            {"v":25, "t":"25"},
            {"v":50, "t":"50"},
            {"v":75, "t":"75"},
            {"v":100, "t":"100"},
            {"v":150, "t":"150"},
            {"v":200, "t":"200"},
            {"v":250, "t":"250"},
            {"v":500, "t":"500"}
        ]')
        @"id": "limit"
        member "attributes"
        {
            @"name": "limit"
            @"class": "form-select rounded-0 no-shadow"
            @"title": "Limitar resultados a..."
            @"onchange": "filter(this);"
        }
        @"value_field": "v"
        @"text_field": "t"
        @"selected": @("#parameters/limit")
    }

    new nav_config
    {
        @"title": "Administración de notificaciones"
        @"urlexit": "javascript:window.history.back();"
        member @"hidden"
        {
            @"print": @true
        }
    }

    // Encapsula a la vista en su totalidad, todo lo que hay antes o después no se considera
    #$
    div(class="container-fluid" id="view")
    {
        link(href="#<@CSS_NOTIMAN>" rel="stylesheet")

        // Filtros y acciones
        section(id="top_area")
        {
            #!
            do uie.printV12FormBar(nav_config)
            #$

            form(class="mb-1" action="./" method="GET" id="form_filter")
            {
                div(class="d-flex align-items-center gap-2 border-bottom")
                {
                    div(class="btn-group" role="group" id="tab-filters" "aria-label"="Basic radio toggle button group")
                    {
                        input(class="btn-check" type="radio" name="_show" value="pendientes" id="rdb-pendientes" onchange="filter(this);" "#<ifstr(show_tab=='pendientes','checked','')>"="")
                        label(class="btn btn-outline-primary border-0 rounded-0" "for"="rdb-pendientes"){$"Pendientes"}

                        input(class="btn-check" type="radio" name="_show" value="leidas" id="rdb-leidas" onchange="filter(this);" "#<ifstr(show_tab=='leidas','checked','')>"="")
                        label(class="btn btn-outline-primary border-0 rounded-0" "for"="rdb-leidas"){$"Leídas"}

                        input(class="btn-check" type="radio" name="_show" value="enviadas" id="rdb-enviadas" onchange="filter(this);" "#<ifstr(show_tab=='enviadas','checked','')>"="")
                        label(class="btn btn-outline-primary border-0 rounded-0" "for"="rdb-enviadas"){$"Enviadas"}
                    }

                    // span(class="text-secondary"){$"|"}

                    // div(class="d-inline-flex align-items-center")
                    // {
                    //     label(class="" "for"="limit"){$"Límite: "}
                    //     ##
                    //     do uie.dbSelect(fil_limit)
                    //     ##
                    // }
                }

                div(class="d-flex align-items-center flex-wrap mt-1 #<ifstr(show_fdr,'','d-none')>")
                {
                    div(class="d-flex align-items-center")
                    {
                        div{ #! do uie.dbSelect(fil_limit) } #$
                        div{ #! do uie.dbSelect(fil_fdr_field) } #$
                    }
                    div(class="flex-grow-1")
                    {
                        "filter-date-range"(
                            "form"="#form_filter"
                            "auto-submit"="true"
                            "custom-range"="true"
                            "selection"='#<to.json(fdr_init)>'

                            "mode-field"="fdr_mode"
                            "year-field"="fdr_year"
                            "month-field"="fdr_month"
                            "range-field"="fdr_range"
                            "from-field"="fdr_from"
                            "to-field"="fdr_to"
                            
                            "lastdays-options"="15,30,45,60,90"
                            "years-options"="#<fdr_year_opt>"
                            "month-names"="Enero,Febrero,Marzo,Abril,Mayo,Junio,Julio,Agosto,Septiembre,Octubre,Noviembre,Diciembre"
                            
                            "label-months"="Ver por cada mes"
                            "label-days"="Últ. @lastdays días"
                            "label-custom"="Personalizado"
                            "label-from"="Desde:"
                            "label-to"="Hasta:"
                        ){$""}
                    }
                }
            }
        }
        // Contenido principal
        section(id="work_area")
        {
            #!
            for i = 0; i < list.count(data)
            {
                ref obj = list.obj(data,i)
                notif_id = @@(obj,"$id")
                target = @@(obj,"$target")
                href = @@(obj,"$href")
                img = @@(obj,"$img")

                show_btn_go = (href != "")
                show_btn_done = (show_tab == "pendientes")
                show_btn_info = (show_tab == "enviadas")

                #$
                div(class="card mb-2 p-1 p-md-3 notif")
                {
                    div(class="notif-grid") //d-flex d-md-row g-0 justify-content-between 
                    {
                        div(class="notif-img-col") //col-md-auto 
                        {
                            figure(class="figure text-center w-100 h-100 m-0")
                            {
                                #! if img != "" {
                                    #$ img(class="figure-img img-fluid rounded ratio ratio-1x1" alt="..." src="#<img>")
                                }
                                #! else if show_tab == "pendientes" {
                                    #$
                                    $'<svg xmlns="http://www.w3.org/2000/svg" width="50" height="50" fill="currentColor" class="bi bi-exclamation-circle" viewBox="0 0 16 16">
                                        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/>
                                        <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0M7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0z"/>
                                    </svg>'
                                }
                                #! else if show_tab == "leidas" {
                                    #$
                                    $'<svg xmlns="http://www.w3.org/2000/svg" width="50" height="50" fill="currentColor" class="bi bi-check-circle" viewBox="0 0 16 16">
                                        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/>
                                        <path d="m10.97 4.97-.02.022-3.473 4.425-2.093-2.094a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-1.071-1.05"/>
                                    </svg>'
                                }
                                #! else if show_tab == "enviadas" {
                                    #$
                                    $'<svg xmlns="http://www.w3.org/2000/svg" width="50" height="50" fill="currentColor" class="bi bi-send" viewBox="0 0 16 16">
                                        <path d="M15.854.146a.5.5 0 0 1 .11.54l-5.819 14.547a.75.75 0 0 1-1.329.124l-3.178-4.995L.643 7.184a.75.75 0 0 1 .124-1.33L15.314.037a.5.5 0 0 1 .54.11ZM6.636 10.07l2.761 4.338L14.13 2.576zm6.787-8.201L1.591 6.602l4.339 2.76z"/>
                                    </svg>'
                                }
                                #! else {
                                    #$
                                    $""
                                }
                                #$
                            }
                        }
                        div(class="notif-body-col") //flex-fill 
                        {
                            div(class="card-body py-0")
                            {
                                h5(class="card-title"){"#<@@(obj,'$title')>"}
                                div(class="card-text"){$"#<@@(obj,'$body')>"}
                                a(class="card-link text-decoration-none expand" href="#" onclick="notiman.vermas(this)"){$"Ver mas"}
                            }
                            div(class="card-footer bg-white py-0")
                            {
                                div(class="d-flex justify-content-between gap-2")
                                {
                                    div(class="" style="white-space:nowrap;"){ small(class="text-muted"){"#<@@(obj,'$start')>"} }
                                    div(class="" style="max-height:1.5rem; overflow:auto;") //white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
                                    {
                                        #!
                                        check0 = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-check-all" viewBox="0 0 16 16"><path d="M8.97 4.97a.75.75 0 0 1 1.07 1.05l-3.99 4.99a.75.75 0 0 1-1.08.02L2.324 8.384a.75.75 0 1 1 1.06-1.06l2.094 2.093L8.95 4.992zm-.92 5.14.92.92a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 1 0-1.091-1.028L9.477 9.417l-.485-.486z"/></svg>'
                                        check1 = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-check-all text-primary" viewBox="0 0 16 16"><path d="M8.97 4.97a.75.75 0 0 1 1.07 1.05l-3.99 4.99a.75.75 0 0 1-1.08.02L2.324 8.384a.75.75 0 1 1 1.06-1.06l2.094 2.093L8.95 4.992zm-.92 5.14.92.92a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 1 0-1.091-1.028L9.477 9.417l-.485-.486z"/></svg>'

                                        usuarios = replace(replace(@@(obj,"$usuarios"), ":0",check0), ":1",check1)
                                        #$
                                        small{$"#<usuarios>"}
                                    }
                                }
                            }
                        }
                        div(class="notif-act-col") //col-md-auto 
                        {$""
                            #!
                            if show_btn_go || show_btn_done || show_btn_info
                            {
                                #$ 
                                div(class="btn-goup d-sm-none notif-gp-act-cont2" role="group")
                                {
                                    //dropdown-toggle
                                    button(class="btn bg-transparent btn-sm rounded-0 no-shadow" type="button" id="notif-group-actions" "data-bs-toggle"="dropdown" "aria-expanded"="false")
                                    {$'<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-three-dots" viewBox="0 0 16 16"><path d="M3 9.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3m5 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3m5 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3"/></svg>'}
                                    ul(class="dropdown-menu" "aria-labelledby"="notif-group-actions")
                                    {$""
                                        #!
                                        if show_btn_info {
                                            // "data-bs-toggle"="offcanvas" "data-source"="#<notif_id>" "data-bs-target"="#notif-info" "aria-controls"="notif-info"
                                            #$ li{ a(class="dropdown-item" href="#" onclick="notiman.getInfo('#<notif_id>')"){$"Info."} }
                                        }
                                        #!
                                        if show_btn_go {
                                            #$ li{ a(class="dropdown-item" href="#" onclick="notiman.goto('#<href>','#<target>',event)"){$"Abrir vínculo"} }
                                        }
                                        #!
                                        if show_btn_done {
                                            #$ li{ a(class="dropdown-item" href="#" onclick="notiman.readed('#<notif_id>',event)"){$"Marcar como leído"} }
                                        }
                                        #$
                                    }
                                }
                                div(class="d-none d-sm-flex flex-lg-row flex-sm-column justify-content-end gap-1 notif-gp-act-cont1")
                                {$""
                                    #!
                                    if show_btn_go {
                                        #$ button(class="btn btn-primary btn-sm" type="button" onclick="notiman.goto('#<href>','#<target>',event)"){$"Abrir vínculo"}
                                    }
                                    #!
                                    if show_btn_done {
                                        #$ button(class="btn btn-light btn-sm" type="button" onclick="notiman.readed('#<notif_id>',event)"){$"Marcar como leído"}
                                    }
                                    #$
                                }
                            }
                            #$
                        }
                    }
                }
            }
            #!
            if list.count(data) < 1 {
                #$ div(class="d-flex justify-content-center align-items-center") {
                    figure(class="figure")
                    {
                        #! if show_tab == "pendientes" {
                            #$
                            img(src="data:image/png;base64," alt="inbox" class="opacity-50 mt-4"){$""}
                        }
                        #! if show_tab == "leidas" {
                            #$
                            img(src="data:image/png;base64," alt="check-inbox--v2" class="opacity-50 mt-4"){$""}
                        }
                        #! if show_tab == "enviadas" {
                            #$
                            $'
                            <svg xmlns="http://www.w3.org/2000/svg" width="144" height="144" fill="currentColor" viewBox="0 0 48 48">
                                <style type="text/css">
                                    .st0 { display: none; }
                                    .st1 {
                                        fill: none;
                                        stroke: #6c757d;
                                        stroke-width: 0.7;
                                        stroke-linecap: round;
                                        stroke-linejoin: round;
                                        stroke-miterlimit: 10;
                                    }
                                    .st2 { fill: #6c757d; }
                                </style>
                                <g class="st0" id="Padding__x26__Artboard" />
                                <g id="Icons">
                                    <g>
                                        <polyline class="st1" points="29.20388,31.39837 34.76982,13.18629 16.555,18.74949 13.23018,23.79638 21.4132,25.36696     21.4132,25.36882 30.95678,16.99933 22.60923,26.63069 24.17982,34.81371 29.20388,31.39837" />
                                        <line class="st1" x1="24.47414" x2="26.14364" y1="17.99184" y2="17.47815" />
                                        <line class="st1" x1="19.1341" x2="23.30684" y1="19.63493" y2="18.35101" />
                                    </g>
                                </g>
                            </svg>
                            '
                        }
                        #$ figcaption(class="figure-caption text-center h5"){$"Sin resultados"}
                    }
                }
            }
            #$
            div(class="offcanvas offcanvas-end" tabindex="-1" id="notif-info" "aria-labelledby"="notif-info-title")
            {
                div(class="offcanvas-header")
                {
                    h5(id="notif-info-title mb-0"){"Información"}
                    button(class="btn-close text-reset" type="button" "data-bs-dismiss"="offcanvas" "aria-label"="Close"){""}
                }
                div(class="offcanvas-body")
                {
                    div(class="bg-light border rounded px-2 mb-1" id="notif-info-message" style="white-space:pre-wrap;"){$""}
                    div(class="card border-0"){div(class="card-body py-1" id="notif-info-users"){$""}}
                }
            }
        }
        // Resúmenes y datos al pie
        section(id="bottom_area")
        {
            //////////////////////////////////////////////////////////////////
            div(id="_custom_area")
            {
                script(src="/$/webshell/js/notiman.js"){$""}
                script(type="text/javascript")
                {$'
                    function filter(fe) { fe.form.submit(); }
                    function between(val,min,max) { return (val >= min && val <= max); }
                    
                    function getCurrentContext() {
                        const table = document.getElementById("#<table_id>");
                        const id = (table?.DataArray[table.CurrentRowIndex()]?.sys_pk ?? "");
                        return { item_id:id, context: {} }
                    }
                    
                    document.addEventListener("DOMContentLoaded", () => {
                        // Script injection
                        #<@@(@crud_context,"script")>
                    });
                '}
            }
        }
    }
    #!

    do @context.end()
}