[
    {
        "id": "webshell",
        "caption": "Entorno Web de V12",
        "help": "Variables del paquete: webshell",
        "vars": 
        [
            {
                "varname": "ws_file_store",
                "vardefault": "data/attatchments/@det/@guid/",
                "varvalue": "data/@qname/attatchments/@det/@guid/",
                "varcaption": "Ruta física de guardado de los archivos",
                "varhelp":"Ruta física de guardado de los archivos para las conversaciones",
                "vartype": "string",
                "varinput": { "control": "text" }
            },
            {
                "varname": "webshell_nav_background_color",
                "vardefault": "",
                "varvalue": "#000000",
                "varcaption": "Color de fondo (navbar y footer)",
                "varhelp":"string con el código de color para el fondo de la navbar y footer",
                "vartype": "string",
                "varinput": { "control": "intcolor" }
            },
            {
                "varname": "webshell_nav_text_color",
                "vardefault": "",
                "varvalue": "#FFFFFF",
                "varcaption": "Color de texto (navbar y footer)",
                "varhelp":"string con el código de color para los textos de la navbar y footer",
                "vartype": "string",
                "varinput": { "control": "intcolor"
                }
            },
            {
                "varname": "webshell_secbg_color",
                "vardefault": "",
                "varvalue": "#FAFAFA",
                "varcaption": "Color de fondo en segundo plano",
                "varhelp":"string con el código de color para el fondo en segundo plano de las vistas",
                "vartype": "string",
                "varinput": { "control": "intcolor" }
            },
            {
                "varname": "webshell_url_secbg_img",
                "vardefault": "",
                "varvalue": "",
                "varcaption": "Imagen de fondo en segundo plano",
                "varhelp":"URL de una imagen para el fondo en segundo plano de las vistas",
                "vartype": "string",
                "varinput": { "control": "text" }
            },
            {
                "varname": "webshell_login_css",
                "vardefault": "",
                "varvalue": "",
                "varcaption": "Estilos CSS para la vista de inicio",
                "varhelp":"Estilos CSS para la vista de inicio",
                "vartype": "string",
                "varinput": { "control": "textarea" }
            },
            {
                "varname": "webshell_login_img",
                "vardefault": "",
                "varvalue": "",
                "varcaption": "Logotipo para la vista de inicio",
                "varhelp":"URL de una imagen para mostrarse en la vista de inicio",
                "vartype": "string",
                "varinput": { "control": "text" }
            },

            {
                "varname": "v12_feedback_url",
                "vardefault": "https://api.induxsoft.net/feedback/",
                "varvalue": "https://api.induxsoft.net/feedback/",
                "varcaption": "URL en donde se enviarán los datos",
                "varhelp":"URL en donde se enviarán los datos de mejoras o sugerencias",
                "vartype": "string",
                "varinput": { "control": "text" }
            },
            {
                "varname": "v12_install_id",
                "vardefault": "f6bc468a7b8b11efa2d4b4b02409fbeb",
                "varvalue": "f6bc468a7b8b11efa2d4b4b02409fbeb",
                "varcaption": "ID v12 instalado",
                "vartype": "string",
                "varinput": { "control": "text" }
            },
            {
                "varname": "webshell_sound_notif",
                "vardefault": "true",
                "varvalue": "true",
                "varcaption": "Permitir Sonido al recibir una notificación",
                "varhelp":"Permitir sonido al recibir una notificacíon",
                "vartype": "bool",
                "varinput": {
                    "control": "select",
                    "source":{
                        "type":"list",
                        "values":
                        [
                            {"val":"true", "text":"Sí"},
                            {"val":"false", "text":"No"}
                        ],
                        "showfield":"text",
                        "keyfield":"val"
                    }
                }
            },
            {
                "varname": "webshell_sound_list",
                "vardefault": "/$/webshell/audio/notification.wav",
                "varvalue": "/$/webshell/audio/notification.wav",
                "varcaption": "Sonidos",
                "varhelp":"Permite seleccionar sonidos",
                "vartype": "string",
                "varinput": 
                { 
                    "control": "audio",
                    "source" :
                    {
                        "showfield":"text",
                        "keyfield":"val",
                        "values":
                        [
                            {"text":"Notificación","val":"/$/webshell/audio/notification.wav"},
                            {"text":"Chat-notificación","val":"/$/webshell/audio/chat.wav"}
                        ]
                    }
                }
            },
            {
                "varname": "webshell_notif_nav",
                "vardefault": "true",
                "varvalue": "true",
                "varcaption": "Notificación del navegador",
                "varhelp":"Permite mostrar alerta de notificaciónes",
                "vartype": "bool",
                "varinput": 
                {
                    "control": "select",
                    "source":{
                        "type":"list",
                        "values":
                        [
                            {"val":"true", "text":"Sí"},
                            {"val":"false", "text":"No"}
                        ],
                        "showfield":"text",
                        "keyfield":"val"
                    }
                }
            },
            {
                "varname": "webshell_chat_news_conv",
                "vardefault": "5",
                "varvalue": "5",
                "varcaption": "Nuevas conversaciones",
                "varhelp":"Tiempo de sondeo de nuevas conversaciones(segundos)",
                "vartype": "number",
                "varinput": 
                {
                    "control": "number"
                }
            },
            {
                "varname": "webshell_chat_news_mess",
                "vardefault": "2",
                "varvalue": "2",
                "varcaption": "Nuevos mensajes",
                "varhelp":"Tiempo de sondeo de mensajes(segundos)",
                "vartype": "number",
                "varinput": 
                {
                    "control": "number"
                }
            },
            {
                "varname": "webshell_bit_news_mess",
                "vardefault": "30",
                "varvalue": "30",
                "varcaption": "Nuevos mensajes",
                "varhelp":"Tiempo de sondeo de mensajes(segundos)",
                "vartype": "number",
                "varinput": 
                {
                    "control": "number"
                }
            },
            {
                "varname": "sys_notif_freq_refresh",
                "vardefault": "30",
                "varvalue": "30",
                "varcaption": "Nuevas notificaciones",
                "varhelp":"Tiempo de sondeo de notificaciones(segundos)",
                "vartype": "number",
                "varinput": 
                {
                    "control": "number"
                }
            }
        ]
    }
]